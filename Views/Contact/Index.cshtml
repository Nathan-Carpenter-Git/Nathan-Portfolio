@model ContactUserMessage

@{
    ViewData["Title"] = "Contact";
    string responseMessage = Context.Request.Query["ResponseMessage"].ToString();
}

<link rel="stylesheet" href="~/css/nathan-portfolio.css" asp-append-version="true" />

<section class="nc-section contact-section">
    <div class="section-label">04</div>
    <h1 class="section-heading">Get In <span>Touch</span></h1>

    <div class="contact-grid">

        <!-- ── Left: info panel ── -->
        <div>
            <p class="contact-info-label">
                Have a question, opportunity, or just want to say hello?<br />
                Fill out the form or check my out other projects directly through the links below
            </p>

            <div class="contact-info-links">
                <a href="https://www.linkedin.com/in/nathan-b-carpenter/" target="_blank" class="contact-info-link">
                    <div class="contact-info-link-icon">in</div>
                    <div class="contact-info-link-text">
                        <span class="contact-info-link-title">LinkedIn</span>
                        <span class="contact-info-link-value">nathan-b-carpenter</span>
                    </div>
                </a>

                <a href="https://github.com/Nathan-Carpenter-Git" target="_blank" class="contact-info-link">
                    <div class="contact-info-link-icon">gh</div>
                    <div class="contact-info-link-text">
                        <span class="contact-info-link-title">GitHub</span>
                        <span class="contact-info-link-value">Nathan-Carpenter-Git</span>
                    </div>
                </a>

                <a href="https://dusty-studios.itch.io" target="_blank" class="contact-info-link">
                    <div class="contact-info-link-icon">it</div>
                    <div class="contact-info-link-text">
                        <span class="contact-info-link-title">itch.io</span>
                        <span class="contact-info-link-value">dusty-studios</span>
                    </div>
                </a>
            </div>
        </div>

        <!-- ── Right: form card ── -->
        <div class="contact-form-card reveal">
            <div class="contact-form-header">
                <span class="form-header-dot"></span>
                <span class="form-header-dot"></span>
                <span class="form-header-dot"></span>
                <span class="form-header-label">// new-message.txt</span>
            </div>

            <div class="contact-form-body">

                @if (!String.IsNullOrEmpty(responseMessage))
                {
                    if (responseMessage == "Email Sent Unsuccessfully")
                    {
                        <div class="nc-response nc-response-error">
                            ✕ &nbsp;@responseMessage — please try again.
                        </div>
                    }
                    else if (responseMessage == "Email Sent Sucessfully")
                    {
                        <div class="nc-response nc-response-success">
                            ✓ &nbsp;@responseMessage — I'll be in touch soon!
                        </div>
                    }
                }

                <form method="post" id="contact-form">

                    <div class="form-row-2">
                        <div class="nc-form-group">
                            <label class="nc-label" for="firstName">First Name</label>
                            <input type="text" id="firstName" name="firstName" asp-for="FirstName"
                                   class="nc-input" placeholder="John" required />
                        </div>

                        <div class="nc-form-group">
                            <label class="nc-label" for="lastName">Last Name</label>
                            <input type="text" id="lastName" name="lastName" asp-for="LastName"
                                   class="nc-input" placeholder="Doe" required />
                        </div>
                    </div>

                    <div class="nc-form-group">
                        <label class="nc-label" for="email">Email Address</label>
                        <input type="email" id="email" name="email" asp-for="Email"
                               class="nc-input" placeholder="john@example.com" required />
                    </div>

                    <div class="nc-form-group">
                        <label class="nc-label" for="message">Message</label>
                        <textarea id="message" name="message" asp-for="Message"
                                  class="nc-textarea" placeholder="Enter your message..."></textarea>
                    </div>

                    <input type="submit" class="nc-submit" value="Send Message" />

                </form>
            </div>
        </div>

    </div>
</section>

<script>
    // Trigger reveal animation on the form card
    const revealEls = document.querySelectorAll('.reveal');
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) entry.target.classList.add('visible');
        });
    }, { threshold: 0.1 });
    revealEls.forEach(el => observer.observe(el));
</script>
