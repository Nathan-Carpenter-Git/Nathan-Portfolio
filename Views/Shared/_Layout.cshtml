<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#040c18" />
    <title>@ViewData["Title"] - Nathan's Portfolio</title>
    @{
        var pageDescription = ViewData["Description"] as string
            ?? "Nathan Carpenter's portfolio - IT & network professional specializing in secure infrastructure, Azure cloud deployments, and systems administration.";
    }
    <meta name="description" content="@pageDescription" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="@ViewData["Title"] - Nathan's Portfolio" />
    <meta property="og:description" content="@pageDescription" />
    <link rel="icon" type="image/x-icon" href="/n-logo.ico" />
    <link rel="preload" href="~/lib/fonts/syne-v24-latin.woff2" as="font" type="font/woff2" crossorigin asp-append-version="true" />
    <link rel="stylesheet" href="~/css/fonts.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/nathan-portfolio.css" asp-append-version="true" />
</head>
<body>

    <!-- ══════════════════════════════
         NAVBAR
    ══════════════════════════════ -->
    <nav class="nc-nav" id="ncNav">
        <a href="/" class="nc-nav-logo">
            <div class="nav-logo-mark">NC</div>
            <span class="nav-logo-text">Nathan <span>Carpenter</span></span>
        </a>

        <ul class="nc-nav-links">
            <li><a href="/" class="nav-index">// Home</a></li>
            <li><a href="/Projects">Projects</a></li>
            <li><a href="/TalkToMe">Talk To Me</a></li>
            <li><a href="/Contact" class="nav-cta">Contact Me</a></li>
        </ul>

        <button class="nc-hamburger" id="ncHamburger" aria-label="Toggle menu">
            <span></span>
            <span></span>
            <span></span>
        </button>
    </nav>

    <!-- Mobile drawer -->
    <div class="nc-mobile-menu" id="ncMobileMenu">
        <ul>
            <li><a href="/">// Home</a></li>
            <li><a href="/Projects">Projects</a></li>
            <li><a href="/TalkToMe">Talk To Me</a></li>
            <li><a href="/Contact" class="nav-cta">Contact Me</a></li>
        </ul>
    </div>

    <!-- ══════════════════════════════
         PAGE CONTENT
    ══════════════════════════════ -->
    <main role="main" class="pb-3">
        @RenderBody()
    </main>

    <!-- ══════════════════════════════
         FOOTER
    ══════════════════════════════ -->
    <footer class="nc-footer">
        <div class="footer-status" id="statusWidget" role="status" aria-live="polite">
            <span class="status-dot" id="statusDot"></span>
            <span class="status-label">SYSTEM</span>
            <span class="status-item">uptime <strong id="statusUptime">--</strong></span>
            <span class="status-item">latency <strong id="statusLatency">--</strong></span>
            <span class="status-item">build <strong id="statusBuild">--</strong></span>
        </div>

        <div class="footer-bottom">
            <p class="footer-copy">
                &copy; @DateTime.UtcNow.Year - <span>Nathan's Portfolio</span>
            </p>
            <ul class="footer-links">
                <li><a href="/">Home</a></li>
                <li><div class="footer-divider"></div></li>
                <li><a href="/Projects">Projects</a></li>
                <li><div class="footer-divider"></div></li>
                <li><a href="/TalkToMe">Talk To Me</a></li>
                <li><div class="footer-divider"></div></li>
                <li>@Html.ActionLink("Contact Me", "Index", "Contact")</li>
            </ul>
        </div>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/status-widget.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <script>
        // Navbar darkens on scroll
        const nav = document.getElementById('ncNav');
        window.addEventListener('scroll', () => {
            nav.classList.toggle('scrolled', window.scrollY > 20);
        });

        // Hamburger toggle
        const btn = document.getElementById('ncHamburger');
        const menu = document.getElementById('ncMobileMenu');

        btn.addEventListener('click', () => {
            const isOpen = menu.classList.toggle('open');
            btn.classList.toggle('open', isOpen);
            btn.setAttribute('aria-expanded', isOpen);
        });

        // Close drawer when a link inside it is tapped
        menu.querySelectorAll('a').forEach(link => {
            link.addEventListener('click', () => {
                menu.classList.remove('open');
                btn.classList.remove('open');
            });
        });

        // Highlight the active nav link
        const path = window.location.pathname;
        document.querySelectorAll('.nc-nav-links a, .nc-mobile-menu a').forEach(a => {
            if (a.getAttribute('href') === path) a.classList.add('active');
        });
    </script>
</body>
</html>
